{
  "name": "eliterank-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:admin": "vite --config admin/vite.config.js",
    "build": "vite build && vite build --config admin/vite.config.js && cp -r admin/dist dist/admin",
    "build:web": "vite build",
    "build:admin": "vite build --config admin/vite.config.js",
